Algoritmo contraseńa
	definir clave Como Caracter
	clave <- "secreta"
	definir intento Como Caracter
	escribir "ingresa la contraseńa"
	leer intento
	mientras intento <> clave Hacer
		escribir "contraseńa incorrecta"
		leer intento
		
	FinMientras
	escribir "acceso concedido"
	
	
FinAlgoritmo
